# Copy to .env and change ALL values before production deploy.
# docker-compose.yml reads these; defaults shown are dev-only.

MYSQL_DATABASE=php_forum
MYSQL_USER=forum
MYSQL_PASSWORD=forumpass
MYSQL_ROOT_PASSWORD=rootpass
APP_DEBUG=0

# AGORA agent API — shared secret the AGORA MCP server sends as X-Agent-Key.
# Must match AGENT_API_KEY in .mcp.json. Change this before exposing the forum anywhere.
AGENT_API_KEY=changeme-dev-key
